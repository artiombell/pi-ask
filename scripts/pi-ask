#!/usr/bin/env bash
# pi-ask: Cross-model consultation wrapper with dynamic model resolution.
#
# Usage:
#   pi-ask <model> [--probe] < context.md
#   pi-ask <model> [--probe] -f <context-file>
#   echo "question" | pi-ask opus
#
# Models are resolved dynamically:
#   - Short aliases (opus, sonnet, haiku, codex, gemini, etc.) resolve to models
#   - claude-* models route to the claude CLI (Anthropic)
#   - Everything else routes to gh copilot CLI (GitHub Copilot)
#   - The model name you type IS the model name sent to the CLI. No hardcoded lists.
#
# --probe: validate model availability (fast PING) without sending context.
#
# Exit codes:
#   0  success
#   1  model not found / ambiguous
#   2  model unavailable (probe failed)
#   4  context file not found
#   5  no stdin and no -f provided

set -euo pipefail

PI_ASK_LAST_PROBE_OUTPUT=""
PROBE_TIMEOUT=${PI_ASK_PROBE_TIMEOUT:-30}    # seconds before probe is killed
STALL_TIMEOUT=${PI_ASK_STALL_TIMEOUT:-120}  # seconds of no output = stall warning

# ---------------------------------------------------------------------------
# Alias table — convenience shortcuts only
# ---------------------------------------------------------------------------
# Format: "alias:canonical_name:provider"
# Provider: anthropic | ghcopilot
# Aliases exist for common short names. Anything not here passes through as-is.

ALIASES=(
  # Anthropic shortcuts
  "opus:claude-opus-4-6:anthropic"
  "sonnet:claude-sonnet-4-6:anthropic"
  "haiku:claude-haiku-4-5:anthropic"
  # OpenAI/Codex shortcuts (via gh copilot)
  "codex:gpt-5.3-codex:ghcopilot"
  "spark:gpt-5.3-codex-spark:ghcopilot"
  "codex-max:gpt-5.1-codex-max:ghcopilot"
  "4o:gpt-4o:ghcopilot"
  # Gemini shortcuts
  "gemini:gemini-3-pro-preview:ghcopilot"
  # Grok shortcuts
  "grok:grok-4:ghcopilot"
  "grok-fast:grok-4-fast:ghcopilot"
  # Mistral shortcuts
  "mistral:mistral-large-latest:ghcopilot"
  "codestral:codestral-latest:ghcopilot"
)

# ---------------------------------------------------------------------------
# Model resolution — alias lookup then passthrough
# ---------------------------------------------------------------------------

infer_provider() {
  # Determine provider from the model name itself.
  # Anthropic models start with "claude-".
  # Everything else goes through gh copilot.
  local model="$1"
  case "$model" in
    claude-*) echo "anthropic" ;;
    *)        echo "ghcopilot" ;;
  esac
}

build_cli() {
  # Build the CLI command for a given provider and model.
  local provider="$1"
  local model="$2"
  case "$provider" in
    anthropic) echo "claude -p --model $model" ;;
    ghcopilot) echo "gh copilot -p PLACEHOLDER --model $model" ;;
    *)         echo "gh copilot -p PLACEHOLDER --model $model" ;;
  esac
}

resolve_model() {
  local input="$1"
  local input_lower
  input_lower=$(echo "$input" | tr '[:upper:]' '[:lower:]' | sed 's/[[:space:]]//g')

  # Phase 1: Exact alias match
  for entry in "${ALIASES[@]}"; do
    local alias canonical provider
    IFS=':' read -r alias canonical provider <<< "$entry"
    if [[ "$input_lower" == "$alias" ]]; then
      local cli
      cli=$(build_cli "$provider" "$canonical")
      echo "$canonical:$provider:$cli"
      return 0
    fi
  done

  # Phase 2: No alias matched — pass through as-is.
  local provider
  provider=$(infer_provider "$input")
  local cli
  cli=$(build_cli "$provider" "$input")
  echo "$input:$provider:$cli"
  return 0
}

# ---------------------------------------------------------------------------
# Auth helpers
# ---------------------------------------------------------------------------

is_auth_failure() {
  local output="${1:-}"
  [[ -n "$output" ]] || return 1
  echo "$output" | grep -Eqi \
    "401|authentication[_[:space:]-]?error|invalid authentication credentials|unauthorized|not[[:space:]]+authenticated|auth[[:space:]]+required|failed to authenticate"
}

load_pi_anthropic_oauth_token() {
  local force="${1:-0}"
  if [[ "$force" != "1" && -n "${ANTHROPIC_OAUTH_TOKEN:-}" ]]; then
    return 0
  fi
  command -v jq >/dev/null 2>&1 || return 1

  local pi_agent_dir auth_file token
  pi_agent_dir="${PI_CODING_AGENT_DIR:-$HOME/.pi/agent}"
  auth_file="${PI_ASK_AUTH_FILE:-$pi_agent_dir/auth.json}"
  [[ -f "$auth_file" ]] || return 1

  token=$(jq -r '.anthropic.access // empty' "$auth_file" 2>/dev/null || true)
  if [[ -z "$token" || "$token" == "null" ]]; then
    return 1
  fi

  export ANTHROPIC_OAUTH_TOKEN="$token"
  echo "pi-ask: loaded Anthropic OAuth token from $auth_file" >&2
  return 0
}

attempt_interactive_anthropic_login() {
  # Login flow requires an interactive TTY (browser/device auth).
  [[ -t 0 && -t 1 ]] || return 1
  if command -v pi >/dev/null 2>&1; then
    echo "pi-ask: opening interactive pi session for Anthropic OAuth." >&2
    echo "pi-ask: in pi, run '/login anthropic', complete browser auth, then '/exit'." >&2
    pi
    return $?
  fi
  command -v claude >/dev/null 2>&1 || return 1
  echo "pi-ask: attempting interactive Anthropic login via 'claude auth login'..." >&2
  claude auth login
}

# ---------------------------------------------------------------------------
# Probe: quick availability check
# ---------------------------------------------------------------------------

probe_model() {
  local provider="$1"
  local cli="$2"
  local canonical="$3"

  echo "Probing $canonical (timeout: ${PROBE_TIMEOUT}s)..." >&2

  local probe_input="respond with exactly: PONG"
  local probe_output
  local probe_exit=0
  local probe_tmp
  probe_tmp=$(mktemp /tmp/pi-ask-probe-XXXXXX)

  if [[ "$provider" == "anthropic" ]]; then
    env -u CLAUDECODE -u CLAUDE_CODE -u CLAUDE_CODE_SESSION \
      timeout "${PROBE_TIMEOUT}" $cli --max-turns 1 <<< "$probe_input" > "$probe_tmp" 2>&1 || probe_exit=$?
  else
    # gh copilot: -p takes the prompt directly, -s for silent output
    timeout "${PROBE_TIMEOUT}" gh copilot -p "$probe_input" --model "$canonical" -s \
      > "$probe_tmp" 2>&1 || probe_exit=$?
  fi

  local raw_output
  raw_output=$(cat "$probe_tmp" 2>/dev/null || true)
  rm -f "$probe_tmp"

  # Check for auth/connection errors first
  if [[ "$provider" != "anthropic" ]]; then
    if echo "$raw_output" | grep -Eqi '401|unauthorized|auth.*fail|not authenticated|error.*login'; then
      PI_ASK_LAST_PROBE_OUTPUT="$raw_output"
      echo "FAIL: $canonical is not available (auth error)" >&2
      echo "$raw_output" | grep -i 'error\|unauthorized\|auth\|login' | head -3 >&2
      return 1
    fi
  fi

  probe_output="$raw_output"
  PI_ASK_LAST_PROBE_OUTPUT="$raw_output"

  # timeout(1) returns 124 on timeout
  if [[ $probe_exit -eq 124 ]]; then
    echo "TIMEOUT: $canonical probe timed out after ${PROBE_TIMEOUT}s" >&2
    return 1
  fi

  if echo "$probe_output" | grep -qi "PONG"; then
    echo "OK: $canonical is available" >&2
    return 0
  else
    echo "FAIL: $canonical is not available" >&2
    if echo "$raw_output" | grep -qi 'not supported\|error\|unavailable\|not found\|invalid model'; then
      echo "$raw_output" | grep -i 'error\|not supported\|unavailable\|not found\|invalid' | head -3 >&2
    fi
    return 1
  fi
}

probe_model_with_recovery() {
  local provider="$1"
  local cli="$2"
  local canonical="$3"

  if probe_model "$provider" "$cli" "$canonical"; then
    return 0
  fi

  if [[ "$provider" != "anthropic" ]] || ! is_auth_failure "$PI_ASK_LAST_PROBE_OUTPUT"; then
    return 1
  fi

  if load_pi_anthropic_oauth_token 1; then
    echo "pi-ask: retrying $canonical probe with PI Anthropic OAuth token..." >&2
    if probe_model "$provider" "$cli" "$canonical"; then
      return 0
    fi
  fi

  if is_auth_failure "$PI_ASK_LAST_PROBE_OUTPUT"; then
    if attempt_interactive_anthropic_login; then
      echo "pi-ask: retrying $canonical probe after login..." >&2
      if probe_model "$provider" "$cli" "$canonical"; then
        return 0
      fi
    fi

    echo "pi-ask: Anthropic authentication failed for $canonical." >&2
    echo "pi-ask: Re-authenticate with one of:" >&2
    echo "  - Open pi and run: /login anthropic" >&2
    echo "  - Run: claude auth login" >&2
  fi

  return 1
}

# ---------------------------------------------------------------------------
# Run model command and stream output
# ---------------------------------------------------------------------------

run_model() {
  local provider="$1"
  local cli="$2"
  local context_file="$3"
  local output_file="$4"  # output captured here
  local canonical="$5"

  if [[ "$provider" == "anthropic" ]]; then
    env -u CLAUDECODE -u CLAUDE_CODE -u CLAUDE_CODE_SESSION \
      $cli < "$context_file" > "$output_file" 2>&1
  else
    # gh copilot: read context from file, pass as prompt via stdin
    local prompt
    prompt=$(cat "$context_file")
    gh copilot -p "$prompt" --model "$canonical" > "$output_file" 2>&1
  fi
}

# Monitor a file for growth. Reports progress to stderr, warns on stall.
# Runs until the given PID exits.
#   monitor_output <file> <pid> <model_name>
monitor_output() {
  local file="$1"
  local pid="$2"
  local model="$3"
  local last_size=0
  local stall_start=0
  local elapsed=0
  local reported_stall=0

  while kill -0 "$pid" 2>/dev/null; do
    sleep 5
    elapsed=$((elapsed + 5))
    local size=0
    [[ -f "$file" ]] && size=$(wc -c < "$file" 2>/dev/null | tr -d ' ')

    if [[ $size -gt $last_size ]]; then
      local delta=$((size - last_size))
      printf "pi-ask: %s output: %d bytes (+%d) [%ds]\n" "$model" "$size" "$delta" "$elapsed" >&2
      last_size=$size
      stall_start=$elapsed
      reported_stall=0
    else
      local stalled_for=$((elapsed - stall_start))
      if [[ $stalled_for -ge $STALL_TIMEOUT && $reported_stall -eq 0 ]]; then
        printf "pi-ask: WARNING: no new output for %ds (model may be thinking or stalled)\n" "$stalled_for" >&2
        reported_stall=1
      elif [[ $((elapsed % 15)) -eq 0 ]]; then
        printf "pi-ask: %s still running... [%ds, %d bytes]\n" "$model" "$elapsed" "$size" >&2
      fi
    fi
  done
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

usage() {
  cat >&2 <<EOF
Usage: pi-ask <model> [options] [-f <context-file>]
       echo "context" | pi-ask <model> [options]

Options:
  --probe               Just check if the model is available, don't send context.
  --list                List shortcut aliases.
  -f <file>             Read context from file instead of stdin.
  --help                Show this help.

Models:
  Any model name accepted by claude CLI or gh copilot CLI works directly:
    pi-ask opus                          # alias -> claude-opus-4-6
    pi-ask claude-sonnet-4-6             # Anthropic, passed through
    pi-ask codex                         # alias -> gpt-5.3-codex via gh copilot
    pi-ask gpt-5.3-codex                # OpenAI via gh copilot
    pi-ask gemini-3-pro-preview          # Gemini via gh copilot
    pi-ask grok-4                        # Grok via gh copilot

  Provider is inferred from the model name:
    claude-*  -> claude CLI (Anthropic)
    *         -> gh copilot CLI (GitHub Copilot)

No timeouts. The model runs until it finishes or you press Ctrl-C.
Context is sent AS-IS. No truncation, no simplification.
EOF
  exit 0
}

main() {
  local model_input=""
  local probe_only=0
  local context_file=""
  local list_models=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --probe)
        probe_only=1
        shift
        ;;
      --list)
        list_models=1
        shift
        ;;
      -f)
        context_file="$2"
        shift 2
        ;;
      --help|-h)
        usage
        ;;
      -*)
        echo "Unknown option: $1" >&2
        usage
        ;;
      *)
        if [[ -z "$model_input" ]]; then
          model_input="$1"
        else
          model_input="$model_input $1"
        fi
        shift
        ;;
    esac
  done

  # --list mode: show aliases only (any model name works, aliases are shortcuts)
  if [[ $list_models -eq 1 ]]; then
    echo "Shortcut aliases (any model name works directly -- these are just shortcuts):"
    echo ""
    printf "  %-15s -> %-35s (%s)\n" "ALIAS" "MODEL" "PROVIDER"
    printf "  %-15s    %-35s --------\n" "-----" "-----"
    for entry in "${ALIASES[@]}"; do
      local alias canonical provider
      IFS=':' read -r alias canonical provider <<< "$entry"
      printf "  %-15s -> %-35s (%s)\n" "$alias" "$canonical" "$provider"
    done
    echo ""
    echo "Any model name not listed above is passed through to the inferred CLI:"
    echo "  claude-*  -> claude -p --model <name>"
    echo "  *         -> gh copilot -p <prompt> --model <name>"
    echo ""
    echo "gh copilot supported models (from --help):"
    echo "  claude-sonnet-4.6, claude-sonnet-4.5, claude-haiku-4.5, claude-opus-4.6,"
    echo "  claude-opus-4.6-fast, claude-opus-4.5, claude-sonnet-4, gemini-3-pro-preview,"
    echo "  gpt-5.4, gpt-5.3-codex, gpt-5.2-codex, gpt-5.2, gpt-5.1-codex-max,"
    echo "  gpt-5.1-codex, gpt-5.1, gpt-5.1-codex-mini, gpt-5-mini, gpt-4.1"
    exit 0
  fi

  if [[ -z "$model_input" ]]; then
    echo "Error: model name required" >&2
    usage
  fi

  # Resolve model
  local resolved
  resolved=$(resolve_model "$model_input") || exit 1

  local canonical provider cli
  IFS=':' read -r canonical provider cli <<< "$resolved"

  echo "pi-ask: resolved '$model_input' -> $canonical ($provider)" >&2
  echo "pi-ask: command: gh copilot -p ... --model $canonical" >&2

  # Probe mode
  if [[ $probe_only -eq 1 ]]; then
    probe_model_with_recovery "$provider" "$cli" "$canonical"
    exit $?
  fi

  # Pre-flight probe: validate model is available before sending context
  if ! probe_model_with_recovery "$provider" "$cli" "$canonical"; then
    echo "" >&2
    echo "pi-ask: model $canonical is not available. Aborting." >&2
    exit 2
  fi

  # Read context
  local tmp_context
  tmp_context=$(mktemp /tmp/pi-ask-context-XXXXXX)
  trap 'rm -f "${tmp_context:-}"; true' EXIT

  if [[ -n "$context_file" ]]; then
    if [[ ! -f "$context_file" ]]; then
      echo "Error: context file not found: $context_file" >&2
      exit 4
    fi
    cp "$context_file" "$tmp_context"
  elif [[ ! -t 0 ]]; then
    cat > "$tmp_context"
  else
    echo "Error: no context provided. Pipe via stdin or use -f <file>." >&2
    exit 5
  fi

  local ctx_size
  ctx_size=$(wc -c < "$tmp_context" | tr -d ' ')
  local ctx_lines
  ctx_lines=$(wc -l < "$tmp_context" | tr -d ' ')
  echo "pi-ask: context size: ${ctx_size} bytes, ${ctx_lines} lines" >&2
  echo "pi-ask: sending full context to $canonical (no truncation)..." >&2
  echo "" >&2

  # Execute: run model in background, monitor output file for progress.
  local model_output
  model_output=$(mktemp /tmp/pi-ask-output-XXXXXX)
  local monitor_pid=""
  local model_pid=""
  trap 'rm -f "${tmp_context:-}" "${model_output:-}"; [[ -n "${monitor_pid:-}" ]] && kill "${monitor_pid}" 2>/dev/null; [[ -n "${model_pid:-}" ]] && kill "${model_pid}" 2>/dev/null; true' EXIT

  local exit_code=0
  echo "pi-ask: $canonical is processing..." >&2

  # Launch model in background
  run_model "$provider" "$cli" "$tmp_context" "$model_output" "$canonical" &
  model_pid=$!

  # Launch monitor in background
  monitor_output "$model_output" "$model_pid" "$canonical" &
  monitor_pid=$!

  # Wait for model to finish
  wait "$model_pid" 2>/dev/null || true
  exit_code=$?
  model_pid=""

  # Stop monitor
  kill "$monitor_pid" 2>/dev/null
  wait "$monitor_pid" 2>/dev/null || true
  monitor_pid=""

  # Read and output results
  local final_size=0
  [[ -f "$model_output" ]] && final_size=$(wc -c < "$model_output" | tr -d ' ')
  echo "pi-ask: $canonical finished (${final_size} bytes output, exit code: $exit_code)" >&2

  if [[ -f "$model_output" && $final_size -gt 0 ]]; then
    cat "$model_output"
  fi

  exit ${exit_code}
}

main "$@"
